# Makefile for Web Interface
.PHONY: web-help web-prod web-dev web-stop web-logs web-clean

web-help:
	@echo "Web Interface Commands:"
	@echo "======================"
	@echo "  web-prod     - Start web interface in production mode"
	@echo "  web-dev      - Start web interface in development mode"
	@echo "  web-stop     - Stop all web interface services"
	@echo "  web-logs     - View logs from running services"
	@echo "  web-clean    - Clean up Docker images and containers"
	@echo ""
	@echo "Services:"
	@echo "  Frontend:    http://localhost:3000 (prod) / http://localhost:5173 (dev)"
	@echo "  API Server:  http://localhost:8000"
	@echo "  WebSocket:   http://localhost:8000"

web-prod:
	@echo "🚀 Starting web interface in production mode..."
	@./todos/start-web-production.sh

web-dev:
	@echo "🚀 Starting web interface in development mode..."
	@./todos/start-web-development.sh

web-stop:
	@echo "🛑 Stopping web interface..."
	@./todos/stop-web.sh

web-logs:
	@echo "📊 Showing logs for running services..."
	@echo "Use Ctrl+C to exit logs"
	@echo ""
	@if docker-compose -f todos/docker-compose.web.yml ps -q > /dev/null 2>&1; then \
		docker-compose -f todos/docker-compose.web.yml logs -f; \
	elif docker-compose -f todos/docker-compose.web-dev.yml ps -q > /dev/null 2>&1; then \
		docker-compose -f todos/docker-compose.web-dev.yml logs -f; \
	else \
		echo "No web services are currently running."; \
	fi

web-clean:
	@echo "🧹 Cleaning up Docker resources..."
	@docker-compose -f todos/docker-compose.web.yml down --volumes --rmi local 2>/dev/null || true
	@docker-compose -f todos/docker-compose.web-dev.yml down --volumes --rmi local 2>/dev/null || true
	@docker system prune -f
	@echo "✅ Cleanup complete!"

# Quick aliases
web: web-dev
web-production: web-prod
web-development: web-dev