#!/bin/bash
# Fast staged-change validation; CI and HOOK_FULL own release validation.
set -euo pipefail

root=$(git rev-parse --show-toplevel)
cd "$root"
paths=$(git diff --cached --name-only)
log_dir="${TMPDIR:-/tmp}/jung-hooks"
mkdir -p "$log_dir"
log="$log_dir/pre-commit-$(date +%s).log"

run() {
  local label=$1; shift
  if "$@" >>"$log" 2>&1; then
    echo "✓ $label"
  else
    echo "✗ $label failed; log: $log" >&2
    tail -n 80 "$log" >&2
    exit 1
  fi
}

git diff --cached --check
run "lint" make hook-commit
if grep -q '^docs/' <<<"$paths"; then run "documentation" make validate-docs; fi
if [ "${HOOK_FULL:-0}" = "1" ]; then run "full finalization" make finalization-check; fi
