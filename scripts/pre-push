#!/bin/bash
# Pre-push hook to run release-candidate validation before pushing
# This ensures finalization-check passes before code is shared

set -e  # Exit on any error

should_run=false
while read -r local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
    case "$local_ref" in
        refs/heads/*) should_run=true ;;
    esac
done

if [ "$should_run" != "true" ]; then
    echo "No branch updates detected; skipping finalization-check."
    exit 0
fi

echo "🔍 Pre-push hook: Running finalization-check..."
echo ""

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT" || exit 1

echo "Running release-candidate validation in Docker..."
echo "This includes lint, contract validation, tests, and the deterministic probe."
echo "Using ENV_FILE=${ENV_FILE:-.env.example} (override by exporting ENV_FILE)."
echo ""

if ENV_FILE="${ENV_FILE:-.env.example}" make finalization-check; then
    echo ""
    echo "✅ Finalization check passed! Proceeding with push."
    echo ""
    exit 0
else
    echo ""
    echo "❌ Finalization check failed! Push aborted."
    echo ""
    echo "To fix:"
    echo "  1. Review the failures above"
    echo "  2. Fix the issues in your code"
    echo "  3. Run 'ENV_FILE=\${ENV_FILE:-.env.example} make finalization-check' to verify fixes"
    echo "  4. Try pushing again"
    echo ""
    echo "To skip this hook (not recommended):"
    echo "  git push --no-verify"
    echo ""
    exit 1
fi
