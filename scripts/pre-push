#!/bin/bash
# Fast branch-aware push validation; set HOOK_FULL=1 for release validation.
set -euo pipefail
updates=false
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_sha" != 0000000000000000000000000000000000000000 ]] && updates=true
done
[[ "$updates" = true ]] || exit 0

root=$(git rev-parse --show-toplevel)
cd "$root"
log_dir="${TMPDIR:-/tmp}/psychoanalyst-hooks"
mkdir -p "$log_dir"
log="$log_dir/pre-push-$(date +%s).log"
run() {
  local label=$1; shift
  if "$@" >>"$log" 2>&1; then echo "✓ $label"; else
    echo "✗ $label failed; log: $log" >&2; tail -n 80 "$log" >&2; exit 1
  fi
}

branch=$(git branch --show-current)
run "fast validation" make hook-push
if [[ "$branch" = "refactor/single-user-architecture" ]]; then
  run "Phase 1 validation" make validate-refactor-phase-1
fi
if [[ "${HOOK_FULL:-0}" = "1" || "$branch" = "main" ]]; then
  run "full finalization" make finalization-check
fi
