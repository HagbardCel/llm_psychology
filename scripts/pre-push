#!/bin/bash
# Fast branch-aware push validation; set HOOK_FULL=1 for release validation.
set -euo pipefail
updates=false
phase_one_push=false
main_push=false
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" != 0000000000000000000000000000000000000000 ]]; then
    updates=true
    [[ "$remote_ref" = "refs/heads/refactor/single-user-architecture" ]] && phase_one_push=true
    [[ "$remote_ref" = "refs/heads/main" ]] && main_push=true
  fi
done
[[ "$updates" = true ]] || exit 0

root=$(git rev-parse --show-toplevel)
cd "$root"
log_dir="${TMPDIR:-/tmp}/psychoanalyst-hooks"
mkdir -p "$log_dir"
log="$log_dir/pre-push-$(date +%s).log"
run() {
  local label=$1; shift
  if "$@" >>"$log" 2>&1; then echo "✓ $label"; else
    echo "✗ $label failed; log: $log" >&2; tail -n 80 "$log" >&2; exit 1
  fi
}

run "fast validation" make hook-push
if [[ "$phase_one_push" = true ]]; then
  run "Phase 1 validation" make validate-refactor-phase-1
fi
if [[ "${HOOK_FULL:-0}" = "1" || "$main_push" = true ]]; then
  run "full finalization" make finalization-check
fi
