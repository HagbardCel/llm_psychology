# Environment Configuration Example
# Copy this file to .env and fill in the values.
#
# ENVIRONMENT FILES:
# - .env          -> Local operation (copy this file)
# - .env.usertest -> Manual testing mode (copy from .env.usertest.template)

# ============================================
# OpenAI-compatible LLM gateway
# ============================================

# Chat Completions base URL (required for real model calls).
# Dockerized api: use host.docker.internal for a model server on the host.
# Native jung-api: prefer 127.0.0.1.
LLM_BASE_URL=http://host.docker.internal:8080/v1

# Optional API key. May be empty for unauthenticated local servers.
# LLM_API_KEY=

# Default model name consumed by jung-api.
MODEL_NAME=local-model

# ============================================
# jung-api runtime
# ============================================

# Data directory for SQLite (`{JUNG_DATA_DIR}/jung.db`).
# Compose sets this per service; for native runs prefer ./data/local.
# JUNG_DATA_DIR=./data/local

# Host bind settings. Native debugger defaults to loopback.
# Containers set JUNG_API_HOST=0.0.0.0 with JUNG_API_ALLOW_REMOTE_BIND=true.
# JUNG_API_HOST=127.0.0.1
# JUNG_API_PORT=8000
# JUNG_API_LOG_LEVEL=info
# Comma-separated browser origins for HTTP CORS and WebSocket Origin checks.
# JUNG_API_ALLOWED_ORIGINS=http://frontend.test
# JUNG_API_ALLOW_REMOTE_BIND=false

# Optional WebSocket adapter timeouts (seconds):
# JUNG_WS_SEND_TIMEOUT=5.0
# JUNG_WS_CLOSE_TIMEOUT=2.0

# Composition / LLM runtime (via load_application_settings):
# JUNG_SHUTDOWN_TIMEOUT=30.0
# JUNG_EVENT_QUEUE_SIZE=64
# JUNG_ENABLE_LLM_TRACING=false
# JUNG_LOG_PROMPT_PREVIEWS=false
# JUNG_LOG_PROMPT_PREVIEWS requires JUNG_ENABLE_LLM_TRACING=true.
# Surrounding single quotes are removed by dotenv and are not part of the JSON value.
# JUNG_LLM_EXTRA_BODY_JSON='{"chat_template_kwargs":{"enable_thinking":false}}'
# JUNG_LLM_TASK_CONFIG_JSON='{"assessment":{"structured_output_mode":"json_object","max_completion_tokens":4096}}'
# JUNG_LLM_DEFAULT_HEADERS_JSON='{"Authorization":"Bearer example"}'
