# Environment Configuration Example
# Copy this file to .env and fill in the values
#
# ENVIRONMENT FILES:
# - .env          -> Development/Production (copy this file)
# - .env.test     -> Automated testing (pre-configured)
# - .env.usertest -> Manual testing mode (copy your API key there if using Gemini)

# ============================================
# API Keys
# ============================================

# Google Gemini API Key (only required when LLM_PROVIDER=gemini)
# Get your key from: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your_gemini_api_key_here

# Generic API key for OpenAI-compatible providers (optional for local llama.cpp)
# LLM_API_KEY=

# ============================================
# LLM Model Configuration (Optional)
# ============================================

# Model policy (override here; code just reads these values)
# Provider options: gemini, ollama, lmstudio, openai_compatible
LLM_PROVIDER=openai_compatible
#
# Optional base URL. Defaults when omitted:
# - ollama: http://host.docker.internal:11434
# - lmstudio: http://host.docker.internal:1234/v1
# - openai_compatible: http://host.docker.internal:8080/v1
# For Dockerized backend services, use host.docker.internal for local host
# model servers rather than localhost.
LLM_BASE_URL=http://host.docker.internal:8080/v1
#
# MODEL_NAME is used by agents without a specific override.
MODEL_NAME=local-model
INTAKE_MODEL=
ASSESSMENT_MODEL=
PSYCHOANALYST_MODEL=
REFLECTION_MODEL=
MEMORY_MODEL=
PLANNING_MODEL=

# ============================================
# Application Environment (Optional)
# ============================================

# Options: production, development, testing
# Default: production
# - production: Normal operation, full session duration (45 min)
# - development: Same as production but with dev tools enabled
# - testing: Used by automated tests, short sessions (1 min)
APP_ENV=production

# ============================================
# Logging Configuration (Optional)
# ============================================

# Enable app file logging (disabled by default for local-lean usage)
APP_FILE_LOGGING_ENABLED=false

# File path for app logs when enabled
# Default: logs/app.log
APP_FILE_LOG_PATH=logs/app.log

# File logging level (applies when APP_FILE_LOGGING_ENABLED=true)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Console logging level (shown in terminal)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: CRITICAL (minimal console output)
CONSOLE_LOG_LEVEL=CRITICAL

# Detailed LLM call payload logging (opt-in; disabled by default)
# When enabled, writes structured entries to logs/llm_calls.log
LLM_CALL_LOGGING_ENABLED=false

# Redact prompt/response/chunk/context payload text in LLM call logs
LLM_CALL_LOGGING_REDACT=true

# Max characters retained per logged text field (when not redacted)
LLM_CALL_LOGGING_MAX_FIELD_CHARS=256

# Include per-stream chunk payload entries in logs (can be very noisy)
LLM_CALL_LOGGING_INCLUDE_CHUNKS=false

# ============================================
# Database Configuration (Optional)
# ============================================

# SQLite database file path
# Default: data/psychoanalyst.db
# DATABASE_PATH=data/psychoanalyst.db

# RAG backend: none (lightweight default) or faiss (optional local retrieval)
# Default: none
# RAG_BACKEND=none

# Vector database path (used when RAG_BACKEND=faiss)
# Default: data/vector_db
# VECTOR_DB_PATH=data/vector_db

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=30

# ============================================
# Session Configuration (Optional)
# ============================================

# Session duration in minutes
# Default: 45
# SESSION_DURATION_MINUTES=45

# ============================================
# Embedding Configuration (Optional)
# ============================================

# Use ONNX backend for faster FAISS embeddings
# USE_ONNX_EMBEDDINGS=true

# Embedding model name
# EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
