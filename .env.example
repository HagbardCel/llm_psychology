# Environment Configuration Example
# Copy this file to .env and fill in the values
#
# ENVIRONMENT FILES:
# - .env          -> Local operation (copy this file)
# - .env.test     -> Automated testing (pre-configured)
# - .env.usertest -> Manual testing mode (copy your API key there if using Gemini)

# ============================================
# API Keys
# ============================================

# Legacy server Google Gemini API key.
# Only required when the legacy server uses LLM_PROVIDER=gemini.
# Get your key from: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your_gemini_api_key_here

# Generic API key for OpenAI-compatible providers.
# `jung-api` reads this for its direct OpenAI-compatible gateway.
# It may be empty for unauthenticated local servers such as llama.cpp.
# LLM_API_KEY=

# ============================================
# LLM Model Configuration (Optional)
# ============================================

# Legacy server provider selection.
# The target `jung-api` uses the direct OpenAI-compatible gateway and does not
# read LLM_PROVIDER.
# Legacy provider options: gemini, ollama, lmstudio, openai_compatible
LLM_PROVIDER=openai_compatible
#
# OpenAI-compatible Chat Completions base URL.
#
# `jung-api` reads this directly and defaults to:
#   http://127.0.0.1:8080/v1
#
# The legacy server also reads it when required by the selected provider.
# Legacy provider defaults when omitted:
# - ollama: http://host.docker.internal:11434
# - lmstudio: http://host.docker.internal:1234/v1
# - openai_compatible: http://host.docker.internal:8080/v1
#
# For Dockerized services, use host.docker.internal for model servers
# running on the host. For native `jung-api`, prefer 127.0.0.1.
LLM_BASE_URL=http://host.docker.internal:8080/v1
#
# MODEL_NAME is consumed by both the legacy server and `jung-api`.
MODEL_NAME=local-model
#
# Legacy server task-specific model overrides (not read by `jung-api`).
INTAKE_MODEL=
ASSESSMENT_MODEL=
THERAPIST_MODEL=
REFLECTION_MODEL=
MEMORY_MODEL=
PLANNING_MODEL=

# Legacy server reasoning configuration (not read by `jung-api`).
# Applies to OpenAI-compatible backends such as llama.cpp and LM Studio.
# Ignored by the legacy Gemini and Ollama providers.
# The console user simulator always disables thinking.
LLM_ENABLE_THINKING=true

# ============================================
# Legacy Server Rate Limiting (Cloud / Remote Only)
# ============================================

# Not read by `jung-api`.
# Local model endpoints bypass legacy client-side rate limiting by policy.
# These settings apply to the legacy Gemini or remote OpenAI-compatible paths.
LLM_RATE_LIMIT_ENABLED=True
LLM_REQUESTS_PER_MINUTE=2.0
LLM_BURST_CAPACITY=2

# ============================================
# Console User Simulator (Optional)
# ============================================
# Used by local-LLM workflow probes (console-ui). Therapist LLM uses LLM_* above.
# Omit USER_SIM_LLM_MODEL to use MODEL_NAME for patient replies.
# USER_SIM_LLM_MODEL=local-model
# Omit USER_SIM_LLM_BASE_URL to use LLM_BASE_URL; if both are omitted, the
# simulator factory defaults to http://host.docker.internal:1234/v1.
# USER_SIM_LLM_BASE_URL=http://host.docker.internal:8080/v1
# USER_SIM_LLM_TEMPERATURE=0
# Local operation: omit cap (0 or unset with APP_ENV=local).
# USER_SIM_LLM_MAX_TOKENS=0
# Local / automated tests: use at least 8192 for reasoning models.
# USER_SIM_LLM_MAX_TOKENS=8192

# ============================================
# Application Environment (Optional)
# ============================================

# Options: local, development, testing
# Default: local
# - local: Normal operation, full session duration (45 min)
# - development: Same as local but with dev tools enabled
# - testing: Used by automated tests, short sessions (1 min)
APP_ENV=local

# ============================================
# Logging Configuration (Optional)
# ============================================

# Enable app file logging (disabled by default for local-lean usage)
APP_FILE_LOGGING_ENABLED=false

# File path for app logs when enabled
# Default: logs/app.log
APP_FILE_LOG_PATH=logs/app.log

# File logging level (applies when APP_FILE_LOGGING_ENABLED=true)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Console logging level (shown in terminal)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: CRITICAL (minimal console output)
CONSOLE_LOG_LEVEL=CRITICAL

# Detailed LLM call payload logging (opt-in; disabled by default)
# When enabled, writes structured entries to logs/llm_calls.log
LLM_CALL_LOGGING_ENABLED=false

# Redact prompt/response/chunk/context payload text in LLM call logs
LLM_CALL_LOGGING_REDACT=true

# Max characters retained per logged text field (when not redacted)
LLM_CALL_LOGGING_MAX_FIELD_CHARS=256

# Include per-stream chunk payload entries in logs (can be very noisy)
LLM_CALL_LOGGING_INCLUDE_CHUNKS=false

# Optional JSONL metrics log. Records phase, call type, provider, model,
# latency, status, and token counts only. Prompt and response text are omitted.
LLM_METRICS_LOG_PATH=

# ============================================
# Target API (`jung-api`) (Optional)
# ============================================

# Data directory for the target SQLite database (`{JUNG_DATA_DIR}/jung.db`)
# JUNG_DATA_DIR=./data
# JUNG_API_HOST=127.0.0.1
# JUNG_API_PORT=8000
# JUNG_API_LOG_LEVEL=info
# JUNG_API_ALLOWED_ORIGINS=
# JUNG_API_ALLOW_REMOTE_BIND=false
#
# Optional WebSocket adapter timeouts (seconds):
# JUNG_WS_SEND_TIMEOUT=5.0
# JUNG_WS_CLOSE_TIMEOUT=2.0
#
# Container example (service not wired until later):
#   JUNG_API_HOST=0.0.0.0
#   JUNG_API_ALLOW_REMOTE_BIND=true
# Publish 127.0.0.1:8000:8000 on the host.

# ============================================
# Database Configuration (Optional)
# ============================================

# SQLite database file path
# Default: data/psychoanalyst.db
# DATABASE_PATH=data/psychoanalyst.db

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=30

# ============================================
# Intake note tracking
# ============================================
# Intake requires canonical structured note tracking; there is no legacy slot path.
# INTAKE_NOTE_TRACKING_STRICT_QUOTE_VALIDATION=true
# INTAKE_NOTE_TRACKING_TIMEOUT_SECONDS=20

# ============================================
# Session Configuration (Optional)
# ============================================

# Session duration in minutes
# Default: 45
# SESSION_DURATION_MINUTES=45
