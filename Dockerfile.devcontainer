# Dockerfile for devcontainer (features injected by devcontainer tooling)
FROM mcr.microsoft.com/devcontainers/base:jammy

# Set working directory
WORKDIR /app

# Switch to vscode user (already exists in base image)
USER vscode

# Features (python, node, git, zsh, etc.) will be injected by devcontainer tooling.
# You can add extra dev-only tools here if needed.