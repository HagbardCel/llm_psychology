# Probe runner image: console-ui plus backend model deps for diagnostics.
#
# The supported console-ui image (Dockerfile) stays lightweight. This image adds
# pydantic so the workflow probe can import the backend's typed IntakeRecord
# models and the canonical intake_record_completion_decision, keeping probe
# diagnostics aligned with backend completeness semantics (no drift).

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

RUN useradd --create-home --shell /bin/bash consoleuser

COPY requirements.txt ./
COPY requirements-probe.txt ./
RUN uv pip install --system -r requirements.txt -r requirements-probe.txt

COPY . .

RUN chown -R consoleuser:consoleuser /app

USER consoleuser

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

CMD ["python", "main.py"]
