{
  "id": "intake_note_tracking",
  "description": "Gate-enabled structured intake note tracking probe: complete intake under the structured completion gate and assert the persisted IntakeRecord covers every required item. Each deterministic patient reply is self-contained so extraction does not depend on the exact direct-ask order chosen by the gate.",
  "user": {
    "name": "Console Probe User",
    "primary_language": "English"
  },
  "persona": {
    "presenting_problem": "work-related anxiety and sleep disruption",
    "coping_attempt": "tried breathing exercises when stressed",
    "style": "cooperative, reflective, concise"
  },
  "workflow_preferences": {
    "therapy_style": "cbt"
  },
  "structural_answers": {
    "profile_selection": "1",
    "profile_name": "Console Probe User",
    "primary_language": "English",
    "therapy_style": "cbt"
  },
  "deterministic_chat_replies": [
    "I struggle with anxiety about work.",
    "This has been going on for three months.",
    "I have not had thoughts of harming myself or anyone else. The chest tightness is not medically urgent.",
    "I tried breathing exercises when Monday deadlines make my chest tight.",
    "I want to sleep better and feel less anxious about Monday deadlines.",
    "I freeze when my manager pressures me about Monday deadlines and my chest tightens.",
    "I have been sleeping badly and keep waking up at night.",
    "This week the Monday deadline made my chest tighten and I worried that I was failing."
  ],
  "intake_note_tracking": {
    "expected": true,
    "require_structured_completion": true,
    "require_canonical_completion_source": true,
    "require_soft_items": ["coping", "sleep_impact"],
    "require_informative_goal": true
  },
  "limits": {
    "max_total_turns": 16,
    "overall_timeout_seconds": 900,
    "api_timeout_seconds": 180,
    "plan_update_timeout_seconds": 360,
    "enrichment_timeout_seconds": 120
  },
  "timing_warning_thresholds_ms": {
    "intake_response_ms": 120000,
    "intake_extraction_ms": 180000,
    "assessment_style_scoring_ms": 180000,
    "assessment_initial_formulation_ms": 180000,
    "initial_plan_generation_ms": 180000,
    "therapy_opening_ms": 120000,
    "therapy_response_ms": 120000,
    "session_enrichment_ms": 300000,
    "session_summary_ms": 300000,
    "memory_analysis_ms": 300000,
    "plan_reflection_ms": 300000,
    "tier1_profile_change_detection_ms": 300000,
    "tier1_profile_update_ms": 300000,
    "tier3_change_detection_ms": 300000,
    "tier3_update_ms": 300000
  },
  "milestones": {
    "required_actions": [
      "start_intake",
      "select_therapy_style",
      "continue_therapy"
    ],
    "minimum_intake_patient_turns": 3,
    "assert_legacy_intake_phrases": false,
    "therapy_response_relevance_terms": [
      "monday",
      "deadline",
      "chest",
      "failing",
      "ceiling",
      "sleep",
      "thought",
      "frustrated",
      "writing",
      "grounding",
      "worry"
    ],
    "minimum_therapy_relevance_terms": 2,
    "forbidden_platform_phrases": [
      "system messages can slip through",
      "therapy plan isn't currently loaded",
      "restore your access"
    ]
  }
}
