# ============================================
# User Testing Environment Configuration
# ============================================
#
# This file provides a template for .env.usertest
# Copy this file to .env.usertest and update with your values
#
# Usage:
#   cp .env.usertest.template .env.usertest
#   # Edit .env.usertest with your actual API key
#   make ui-console-test
#
# ============================================

# Google Gemini API Key (Required)
# Copy your actual key from .env or get one from:
# https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini

# Model selection (user testing uses the lightweight model everywhere)
MODEL_NAME=gemini-2.5-flash-light
INTAKE_MODEL=
ASSESSMENT_MODEL=
THERAPIST_MODEL=
REFLECTION_MODEL=
MEMORY_MODEL=
PLANNING_MODEL=

# Logging Configuration
# DEBUG provides more detailed output for testing
LOG_LEVEL=DEBUG
CONSOLE_LOG_LEVEL=INFO

# Database Configuration
# Isolated database for usertest mode (separate from local operation)
DATABASE_PATH=data/psychoanalyst_usertest.db
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=30

# Local LLM user simulator (console workflow probes)
USER_SIM_LLM_BASE_URL=http://host.docker.internal:8080/v1
USER_SIM_LLM_TEMPERATURE=0
USER_SIM_LLM_MAX_TOKENS=8192

# Application Configuration
APP_ENV=development

# Session Configuration
# Shorter sessions for faster manual testing
# Production: 45 minutes | Usertest: 10 minutes | Automated tests: 1 minute
SESSION_DURATION_MINUTES=10

# ============================================
# Notes:
# ============================================
#
# - Usertest mode uses isolated databases to avoid
#   polluting local data during testing
#
# - Shorter session duration (10 min) allows for
#   faster iteration during manual testing
#
# - All usertest data is stored separately:
#   * Database: data/psychoanalyst_usertest.db
# - To clean usertest data:
#   make clean-testdb
#
# ============================================
