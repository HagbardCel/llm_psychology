# ============================================
# User Testing Environment Configuration
# ============================================
#
# Template for .env.usertest
# Copy this file to .env.usertest and configure the OpenAI-compatible gateway.
#
# Usage:
#   cp .env.usertest.template .env.usertest
#   # Edit .env.usertest with LLM_BASE_URL and MODEL_NAME
#   make ui-console-test
#
# ============================================

# OpenAI-compatible Chat Completions base URL (required, non-placeholder).
# For a Dockerized api service talking to a host model server:
LLM_BASE_URL=http://host.docker.internal:8080/v1

# Optional API key. Unauthenticated local endpoints are valid; leave empty.
# LLM_API_KEY=

# Model selection (required, non-placeholder).
MODEL_NAME=local-model

# Optional Jung LLM overrides (see .env.example).
# JUNG_LLM_EXTRA_BODY_JSON=
# JUNG_LLM_TASK_CONFIG_JSON=
# JUNG_LLM_DEFAULT_HEADERS_JSON=

# Logging (optional)
# JUNG_API_LOG_LEVEL=debug

# ============================================
# Notes
# ============================================
#
# - `make ui-console-test` assigns JUNG_DATA_DIR=/app/data/usertest for the
#   parameterized api service. Do not set DATABASE_PATH; the target runtime
#   uses jung.db under JUNG_DATA_DIR.
# - LLM_API_KEY is optional for unauthenticated local OpenAI-compatible servers.
# - To clean usertest data, stop the usertest containers and remove
#   data/usertest/jung.db together with any -wal and -shm siblings.
#
# ============================================
